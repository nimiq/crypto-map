# PostgreSQL (single remote database for local dev and runtime)
DATABASE_URL=postgresql://postgres.your-project-ref:password@aws-1-your-region.pooler.supabase.com:5432/postgres

# API Keys
GOOGLE_API_KEY=your_google_api_key_here
OPENAI_API_KEY=your_openai_api_key_here

# Site URL (required in production for Cloudflare Image Resizing)
NUXT_PUBLIC_SITE_URL=https://crypto-map.je-cf9.workers.dev

# NuxtHub Self-Hosting (for local --remote dev and blob presigned URLs)
NUXT_HUB_CLOUDFLARE_ACCOUNT_ID=
NUXT_HUB_CLOUDFLARE_API_TOKEN=
NUXT_HUB_CLOUDFLARE_BUCKET_ID=
NUXT_HUB_CLOUDFLARE_CACHE_NAMESPACE_ID=
